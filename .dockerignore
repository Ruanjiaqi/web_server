# ── Git ──────────────────────────────────────────────────
.git
**/.git

# ── 运行时生成内容（每次容器启动会重建）──────────────────────
crmeb/runtime/
crmeb/.env
crmeb/supervisord.log
crmeb/backup/
# install.lock 必须排除：若打入镜像会让 init 跳过安装，.env 为空导致 DB 连接失败
crmeb/public/install.lock

# ── 开发/测试文件 ─────────────────────────────────────────
**/.DS_Store
**/Thumbs.db
**/*.docx

# ── vendor 内的日志文件（避免权限问题）───────────────────────
crmeb/vendor/**/*.log

# 字体文件不排除：
# - WenQuanZhengHei.ttf 被 ajcaptcha 用于验证码文字渲染（imagettfbbox）
# - simsun.ttc 被 think-qrcode 用于二维码生成
# 排除后会报 "Could not find/open font" 错误

# ── 前端模板源码（非 PHP 运行时需要）──────────────────────────
template/
