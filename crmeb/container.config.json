{
  "name": "crmeb-fmcg",
  "description": "CRMEB FMCG backend container for local Docker and WeChat CloudBase Run",
  "containerPort": 80,
  "healthCheck": {
    "path": "/",
    "initialDelaySeconds": 10,
    "periodSeconds": 10
  },
  "env": [
    "DB_HOST",
    "DB_PORT",
    "DB_DATABASE",
    "DB_USERNAME",
    "DB_PASSWORD",
    "REDIS_HOST",
    "SITE_URL",
    "WECHAT_PAY_MCHID",
    "WECHAT_PAY_KEY_V3",
    "WECHAT_PAY_SERIAL_NO",
    "WECHAT_PAY_CERT_PATH",
    "WECHAT_PAY_CERT",
    "WECHAT_PAY_CERT_CONTENT",
    "WECHAT_PAY_PRIVATE_KEY_PATH",
    "WECHAT_PAY_PRIVATE_KEY",
    "WECHAT_PAY_PRIVATE_KEY_CONTENT",
    "WECHAT_PAY_PROFIT_SHARING_NOTIFY_URL",
    "WECHAT_PAY_NOTIFY_URL",
    "WECHAT_PAY_TRANSFER_NOTIFY_URL"
  ]
}
