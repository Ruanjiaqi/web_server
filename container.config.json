{
  "containerPort": 80,
  "dockerfilePath": "Dockerfile",
  "buildDir": "",
  "minNum": 1,
  "maxNum": 5,
  "cpu": 2,
  "mem": 4,
  "policyType": "cpu",
  "policyThreshold": 60,
  "policyDetails": [
    {
      "PolicyType": "cpu",
      "PolicyThreshold": 60
    },
    {
      "PolicyType": "mem",
      "PolicyThreshold": 80
    }
  ],
  "envParams": {
    "MYSQL_DATABASE": "crmeb",
    "REDIS_DATABASE": "0",
    "CRMEB_ADMIN_USER": "admin",
    "CRMEB_ADMIN_PWD": "crmeb.com",
    "APP_DEBUG": "false",
    "DEFAULT_TIMEZONE": "Asia/Shanghai"
  },
  "customLogs": "stdout",
  "initialDelaySeconds": 30,
  "dataBaseName": "crmeb",
  "executeSQLs": [
    "CREATE DATABASE IF NOT EXISTS `crmeb` DEFAULT CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
  ]
}
